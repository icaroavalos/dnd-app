{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"],
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@shared/contracts": ["./src/shared/contracts/index.ts"],
      "@shared": ["./src/shared/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
